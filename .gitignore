.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Data files (keep schema, ignore large data)
# Uncomment if you want to ignore large data files
# data/*.json
# !data/*_schema.json

# Temporary files
*.tmp
*.temp
.cache/

# GitHub Actions
.github/workflows/debug.yml
