    {
      "name": "Wireshark",
      "description": "Network protocol analyzer for deep packet inspection and troubleshooting",
      "category": "Network",
      "installation": {
        "windows": "winget install Wireshark.Wireshark --source winget",
        "linux_debian": "sudo apt install wireshark",
        "linux_rhel": "sudo dnf install wireshark",
        "linux_arch": "sudo pacman -S wireshark-qt",
        "macos": "brew install wireshark"
      },
      "url": "https://www.wireshark.org/"
    },
